PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/scope_db?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_different_from_jwt_secret
ALLOWED_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password


# Weekly Digest Cron
# Cron expression for digest schedule (default: Sunday 8 AM IST)
DIGEST_CRON=0 8 * * 0
# Set to true to fire digest immediately on server start (for testing only)
DIGEST_RUN_ON_START=false


NODE_ENV=development
